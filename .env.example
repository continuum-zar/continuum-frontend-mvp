# API base URL (optional).
# Defaults to /api/v1 which routes through the Vite dev proxy (same-origin, no CORS).
# Production / custom hosts: set the full API base URL.
# VITE_API_BASE_URL=https://api.example.com/api/v1

# Vite proxies /api to this target (see vite.config.mjs).
# Backend on host:
# VITE_PROXY_TARGET=http://localhost:8001
# Backend in Docker (from Vite on host):
# VITE_PROXY_TARGET=http://host.docker.internal:8001

# Public URL of the hosted Continuum MCP server.
# Used to generate the Cursor mcp.json snippet users can copy.
# VITE_MCP_PUBLIC_URL=https://continuum-mcp.up.railway.app

# Google Calendar (GIS token + Calendar API) for sprint calendar view — OAuth Web client ID.
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# TanStack Query Devtools (floating inspector). Off unless explicitly enabled.
# Set in .env.local when you want to inspect queries (local dev or Docker dev).
# VITE_ENABLE_QUERY_DEVTOOLS=true
