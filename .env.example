# Use the Vite proxy (no CORS issues, export works). Do NOT set VITE_API_BASE_URL.
# All API calls go to /api/v1 (same origin) and are proxied to the backend.

# Backend URL for the proxy (default in vite.config is http://localhost:8001).
# When the backend runs in Docker, use:
VITE_PROXY_TARGET=http://host.docker.internal:8001

# When the backend runs on the host (not Docker), use:
# VITE_PROXY_TARGET=http://localhost:8001
