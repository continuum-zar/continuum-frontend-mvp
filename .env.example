# API base URL (optional).
# Defaults to /api/v1 which routes through the Vite dev proxy (same-origin, no CORS).
# Production / custom hosts: set the full API base URL.
# VITE_API_BASE_URL=https://api.example.com/api/v1

# Vite proxies /api to this target (see vite.config.mjs).
# Backend on host:
# VITE_PROXY_TARGET=http://localhost:8001
# Backend in Docker (from Vite on host):
# VITE_PROXY_TARGET=http://host.docker.internal:8001
